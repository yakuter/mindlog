{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mindlog",
  "version": "0.1.0",
  "identifier": "com.erhanyakut.mindlog",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MindLog",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFODkzQkZBNkE5NkQ3QUEKUldTcTE1WnEranVKSHR3RVZTOWh2UUdZaHlDWEtrS25NYXJKZEtJR0wwSTFYa3pJSVRldXd2QWwK",
      "endpoints": [
        "https://github.com/yakuter/mindlog/releases/latest/download/latest.json"
      ]
    }
  }
}
